# ── Supabase ───────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://db.SEUPROJETO.supabase.co:5432/postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=SUA_SENHA_SUPABASE

# Se sua senha tiver `$`, escape como `$$` no arquivo `.env` (o Docker Compose faz expansão de variáveis).

# ── JWT ────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=COLOQUE_UMA_CHAVE_SECRETA_LONGA_AQUI

# ── Grok API ───────────────────────────────────────────────────────
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_MODEL=grok-3-mini-fast

# ── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BASIC=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxx

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000