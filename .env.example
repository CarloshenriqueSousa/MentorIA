# Copie para `.env` na raiz e preencha com seus valores.
# No Docker Compose, `$` na senha do banco deve ser escrito como `$$`.

DATABASE_URL=jdbc:postgresql://db.SEU_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_USER=postgres
DATABASE_PASSWORD=SUA_SENHA_DO_SUPABASE

JWT_SECRET=GERE_UMA_CHAVE_LONGA_E_ALEATORIA

SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_KEY=SUA_CHAVE_ANON_OU_PUBLISHABLE
# Opcional: só no backend/Docker — nunca no frontend
SUPABASE_SERVICE_ROLE_KEY=

# Obrigatório para validar login Supabase no Spring (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_BASIC=price_placeholder
STRIPE_PRICE_PREMIUM=price_placeholder

# Inclua a porta do Nuxt (padrão do projeto: 3001) para o browser poder chamar a API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Opcional: o Nuxt lê o `.env` da raiz; estes são aliases se quiser duplicar
NUXT_PUBLIC_API_BASE=http://localhost:8080/api
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=
