# Copie para `.env` na raiz e preencha com seus valores.
# Valores abaixo funcionam com `docker compose up -d postgres`.

# Opcional: sobe o Postgres via Docker Compose ao iniciar o backend (requer Docker)
# DOCKER_COMPOSE_ENABLED=true

DATABASE_URL=jdbc:postgresql://localhost:5432/mentoria?sslmode=disable
DATABASE_USER=mentoria
DATABASE_PASSWORD=mentoria

JWT_SECRET=MentorIASecretKeyMustBeAtLeast256BitsLongForSecurity

ANTHROPIC_API_KEY=sk-ant-api03-SEU_KEY_AQUI
CLAUDE_MODEL=claude-3-5-sonnet-latest

STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_BASIC=price_placeholder
STRIPE_PRICE_PREMIUM=price_placeholder
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

NUXT_PUBLIC_API_BASE=/api
