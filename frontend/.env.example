# Opcional: o Nuxt carrega automaticamente o `.env` da raiz do repositório.
# Use este arquivo só para overrides (ex.: API em outro host).
NUXT_PUBLIC_API_BASE=http://localhost:8080/api

# Obrigatório para @nuxtjs/supabase (lê no build)
SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_KEY=SUA_CHAVE_PUBLISHABLE_OU_ANON

# Opcional: aliases para runtimeConfig legado
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=
